# Supabase (Production)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase (Local Development)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# OAuth Providers
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your_google_client_id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your_google_client_secret

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://ajussi-rental.com

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# PayApp (페이앱 결제)
# 판매자 아이디는 비밀값이 아니므로 클라이언트에 노출 가능
NEXT_PUBLIC_PAYAPP_USERID=your_payapp_userid
NEXT_PUBLIC_PAYAPP_SHOPNAME=아저씨렌탈
NEXT_PUBLIC_PAYAPP_OPENPAYTYPE=card,kakaopay,naverpay
# 연동 KEY/VALUE - 페이앱 판매자 사이트 > 설정 > 연동정보 (서버 전용, 절대 커밋 금지)
PAYAPP_LINKKEY=your_payapp_linkkey
PAYAPP_LINKVAL=your_payapp_linkval

# Notifications (알림)
NOTIFY_EMAIL_ENABLED=false
RESEND_API_KEY=your_resend_api_key
NOTIFY_FROM_EMAIL=noreply@ajussirental.com
ADMIN_EMAIL=your_admin_email
NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id